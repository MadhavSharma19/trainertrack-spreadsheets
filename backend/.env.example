# JWT Secret
JWT_SECRET=trainer-tracker-secret-2024

# Port
PORT=4000

# ──────────────────────────────────────────────────────────
# Google Sheets Sync (optional — enables "Sync to Google Sheets")
# ──────────────────────────────────────────────────────────
# 1. Go to Google Cloud Console → Create a Service Account
# 2. Download the JSON key file
# 3. Share your Google Sheet with the service account email (Editor)
# 4. Paste the ENTIRE JSON key file content (as a single line) below
# 5. Set the Sheet ID from your Google Sheet URL:
#    https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_ID/edit

GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
